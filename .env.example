# TunnelKit Server
PORT=8080
DATABASE_URL=postgres://tunnelkit:tunnelkit@localhost:5432/tunnelkit?sslmode=disable
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=change-me-in-production-use-64-char-random
API_SECRET=change-me-in-production-use-64-char-random
BASE_DOMAIN=localhost:8080
TLS_ENABLED=false
TLS_CERT_PATH=
TLS_KEY_PATH=

# TunnelKit CLI (set in shell or ~/.tunnelkit.yml)
TUNNELKIT_SERVER=https://tunnel.localhost
TUNNELKIT_TOKEN=your-api-token-here
